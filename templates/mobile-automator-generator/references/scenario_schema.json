{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Mobile QA Test Scenario",
  "description": "Schema for mobile QA test scenario files generated by /mobile-automator:generate",
  "type": "object",
  "required": [
    "scenario_id",
    "name",
    "description",
    "platform",
    "app_package",
    "metadata",
    "steps",
    "assertions"
  ],
  "properties": {
    "scenario_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Unique identifier in snake_case"
    },
    "name": {
      "type": "string",
      "description": "Human-readable name of the test scenario"
    },
    "description": {
      "type": "string",
      "description": "What this scenario tests"
    },
    "platform": {
      "type": "string",
      "enum": [
        "android",
        "ios",
        "cross-platform"
      ]
    },
    "app_package": {
      "type": "string",
      "description": "Bundle ID or package name of the app under test"
    },
    "metadata": {
      "type": "object",
      "required": [
        "app_version",
        "device_model",
        "api_level",
        "environment",
        "timestamp"
      ],
      "properties": {
        "app_version": {
          "type": "string",
          "description": "Build variant or version (e.g., '2.4.1-debug')"
        },
        "device_model": {
          "type": "string",
          "description": "Device name (e.g., 'Pixel 8 Pro', 'iPhone 16')"
        },
        "api_level": {
          "type": "string",
          "description": "Android API level or iOS version (e.g., '34', '18.1')"
        },
        "environment": {
          "type": "string",
          "description": "Target environment (e.g., 'production', 'staging', 'development')"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO-8601 datetime of scenario generation"
        }
      }
    },
    "preconditions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Required state before test execution"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$",
        "maxLength": 20
      },
      "maxItems": 10,
      "uniqueItems": true,
      "description": "Categorization tags for filtering. Format: lowercase alphanumeric + hyphens only (e.g., 'smoke', 'regression', 'p0'). Max 10 tags per scenario, max 20 characters per tag."
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "step_id",
          "action",
          "description"
        ],
        "properties": {
          "step_id": {
            "type": "integer",
            "minimum": 1
          },
          "action": {
            "type": "string",
            "enum": [
              "launch_app",
              "tap",
              "type",
              "swipe",
              "press_button",
              "wait",
              "open_url"
            ]
          },
          "description": {
            "type": "string",
            "description": "What this step does in plain language"
          },
          "target": {
            "type": "string",
            "description": "Element description or coordinates"
          },
          "value": {
            "type": [
              "string",
              "null"
            ],
            "description": "Input text, swipe direction, button name, etc."
          },
          "checkpoint": {
            "type": "boolean",
            "default": false,
            "description": "Whether to capture a reference screenshot"
          },
          "expected_state": {
            "type": [
              "string",
              "null"
            ],
            "description": "Description of expected visual state"
          }
        }
      }
    },
    "assertions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "assertion_id",
          "after_step_id",
          "type"
        ],
        "properties": {
          "assertion_id": {
            "type": "integer",
            "minimum": 1
          },
          "after_step_id": {
            "type": "integer",
            "description": "Which step to assert after"
          },
          "type": {
            "type": "string",
            "enum": [
              "screenshot_match",
              "element_exists",
              "element_text",
              "element_not_exists"
            ]
          },
          "reference_screenshot": {
            "type": [
              "string",
              "null"
            ],
            "description": "Relative path to reference image"
          },
          "element_description": {
            "type": [
              "string",
              "null"
            ]
          },
          "expected_value": {
            "type": [
              "string",
              "null"
            ]
          },
          "tolerance": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0,
            "default": 0.9,
            "description": "Similarity threshold for screenshot comparison"
          }
        }
      }
    }
  }
}