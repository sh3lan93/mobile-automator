# Dependencies
# No trailing slash so a `node_modules` SYMLINK (used to share deps into
# nested worktrees) is ignored too — a trailing-slash pattern matches only a
# directory and let the symlink slip into git once (fixed here).
node_modules

# Build output
dist/

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Environment files
.env
.env.local

# Test artifacts
testscenarios/
screenshots/

# Product Documentation
product-documentation/

prototypes/
.planning-archive/
site/
.worktrees/
docs/superpowers/

# Mobile Automator device session daemon (socket / pidfile / handle)
mobile-automator/.session/

# sample-app (Flutter) build artifacts
sample-app/build/
sample-app/.dart_tool/
sample-app/.flutter-plugins
sample-app/.flutter-plugins-dependencies
sample-app/ios/Pods/
sample-app/ios/.symlinks/
sample-app/android/.gradle/
sample-app/android/local.properties