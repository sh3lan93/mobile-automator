# TestRail Configuration (Optional)
# If your team uses TestRail for test case management, set these variables
# to enable TestRail integration with mobile-automator

TESTRAIL_API_KEY=your_api_key_here
TESTRAIL_DOMAIN=your-company.testrail.io

# Notes:
# - TESTRAIL_API_KEY: Generate in TestRail Settings → API Tokens
# - TESTRAIL_DOMAIN: Your TestRail instance domain (without https://)
# - Do NOT commit actual credentials to .env (add .env to .gitignore)
